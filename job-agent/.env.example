# LLM
LLM_BACKEND=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
ANTHROPIC_API_KEY=
LLM_MODEL=deepseek-chat
JUDGE_BACKEND=mock
JUDGE_MODEL=deepseek-chat

# Embedding
# hash | local | siliconflow
EMBEDDING_BACKEND=hash
EMBEDDING_DIM=384
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_LOCAL_RERANKER=false
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
# To use SiliconFlow bge-m3, set:
# EMBEDDING_BACKEND=siliconflow
# EMBEDDING_DIM=1024

# Database
DATABASE_URL=postgresql+asyncpg://jobagent:jobagent@127.0.0.1:5432/jobagent
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=job_agent_chunks
ENABLE_VECTOR_SEARCH=true

# App
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]
